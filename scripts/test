#!/usr/bin/env bash
# test - the dum dictation dev gate. Run before every commit.
#
#   scripts/test            # unit tests + bench (fast) vs baseline; fails on regression
#   scripts/test --realtime # bench at mic cadence too (adds true settle latency)
#   scripts/test --update   # accept current bench numbers as the new baseline
#   scripts/test --unit     # unit tests only, skip the bench (no models/corpus needed - this is
#                           # what CI runs, so a fresh clone with no voice data goes green)
#
# Unit tests (pure logic): pipeline text cleanups + overlay diff/reconcile.
# Bench (real pipeline): replays the golden corpus through live.py and scores WER /
# IT-term recall / preview proc, comparing to tests/baseline.json. Corpus audio is
# local-only (voice) - bench skips fixtures whose WAV isn't present.
set -uo pipefail
cd "$(dirname "$0")/.." || exit 1
# engine code lives in src/; tests/ import it flat (`import pipeline`), so put src/ on the
# path. (Resources like terms.txt/models/ stay at the root, found via HERE in the modules.)
export PYTHONPATH="$PWD/src${PYTHONPATH:+:$PYTHONPATH}"
PY=.venv/bin/python
fail=0

echo "== unit: pipeline =="
$PY tests/test_pipeline.py || fail=1
echo "== unit: overlay =="
$PY tests/test_overlay.py  || fail=1
echo "== unit: llm-guard =="
$PY tests/test_llm_guard.py || fail=1
echo "== unit: llm-backend seam =="
$PY tests/test_llm_backend.py || fail=1
echo "== unit: repo-harvest =="
$PY tests/test_repo_harvest.py || fail=1
echo "== unit: fuzzy-recover (safety gate) =="
$PY tests/test_fuzzy_recover.py || fail=1
echo "== unit: dogfood-log =="
$PY tests/test_dogfood_log.py || fail=1
echo "== unit: activity-monitor =="
$PY tests/test_activity_monitor.py || fail=1
echo "== unit: insertion-seam =="
$PY tests/test_insertion.py || fail=1
echo "== unit: early-stop dataloss (half-applied reconcile) =="
$PY tests/test_early_stop.py || fail=1
echo "== unit: focus-away guard (alt-tab hard stop) =="
$PY tests/test_focus_guard.py || fail=1
echo "== unit: config + first-run wizard =="
$PY tests/test_config.py || fail=1
echo "== unit: single-instance guard =="
$PY tests/test_single_instance.py || fail=1
echo "== unit: autostart (launchd plist + windows task xml) =="
$PY tests/test_autostart.py || fail=1
echo "== unit: tray controller =="
$PY tests/test_tray.py || fail=1
echo "== unit: platform dispatch (mac/windows/fallback) =="
$PY tests/test_platform_dispatch.py || fail=1
echo "== unit: linux platform (x11/wayland backend) =="
$PY tests/test_linux_platform.py || fail=1
echo "== unit: evdev hotkey (device selection / feedback-loop filter) =="
$PY tests/test_evdev_hotkey.py || fail=1
echo "== unit: paste-atomic (clipboard save/restore) =="
$PY tests/test_platform_paste.py || fail=1
echo "== unit: lock-trim =="
# exit 77 = skipped (corpus/model absent); any OTHER nonzero = a real regression, so
# don't mask it as "skipped".
$PY tests/test_lock_trim.py >/dev/null 2>&1; rc=$?
if [[ $rc -eq 0 ]]; then echo "lock-trim bench OK"
elif [[ $rc -eq 77 ]]; then echo "lock-trim bench skipped (corpus audio absent)"
else echo "lock-trim bench FAILED (rc=$rc)"; fail=1; fi
echo "== stt: smoke (real recognizer, committed WAV) =="
# Self-skips (exit 0) when the Parakeet model isn't present, so a fresh clone with no
# models still passes --unit; when the model IS present (locally or via the CI download
# step) it actually decodes audio and gates on WER.
$PY tests/test_stt_smoke.py || fail=1

if [[ " $* " == *" --unit "* ]]; then
  echo ""
  if [[ $fail -eq 0 ]]; then echo "UNIT GREEN (bench skipped)"; else echo "FAILURES - see above"; fi
  exit $fail
fi

echo "== bench: real pipeline vs baseline =="
BENCH_ARGS=()
[[ " $* " == *" --realtime "* ]] && BENCH_ARGS+=(--realtime)
[[ " $* " == *" --update "* ]]   && BENCH_ARGS+=(--update-baseline)
$PY src/bench.py "${BENCH_ARGS[@]:-}" || fail=1

echo ""
if [[ $fail -eq 0 ]]; then echo "ALL GREEN"; else echo "FAILURES - see above"; fi
exit $fail
